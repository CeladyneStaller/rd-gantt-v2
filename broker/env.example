# Copy to Railway service variables (do NOT commit a filled-in copy).

# JSONBin master key — stays server-side; the browser never sees it.
JSONBIN_MASTER_KEY=your-jsonbin-master-key

# Bin ids. These MUST match the bin ids configured in the Division Tracker's
# Settings (the client still reads these bins directly). EXP is optional —
# leave unset if Exploration isn't in use; its writes will 400 until set.
JSONBIN_BIN_HUB=overall-gantt-bin-id
JSONBIN_BIN_FC=fuelcell-bin-id
JSONBIN_BIN_EL=electrolyzer-bin-id
JSONBIN_BIN_EXP=

# Bearer token the browser presents on every write. Generate a long random
# string; rotate by changing it here and in the client's Settings. This is the
# revocable credential that replaces shipping the master key to the browser.
BROKER_TOKEN=generate-a-long-random-string

# Comma-separated allow-list of browser origins (GitHub Pages + Confluence).
# Leave unset only for local testing (falls back to '*').
ALLOWED_ORIGINS=https://celadynestaller.github.io,https://your-confluence-domain
